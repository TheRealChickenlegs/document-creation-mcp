{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "{{checkpoint}}" }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": { "clip": ["1", 0], "text": "{{prompt}}" }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": { "clip": ["1", 0], "text": "{{negative_prompt}}" }
  },
  "4": {
    "class_type": "IPAdapterModelLoader",
    "inputs": { "model_name": "ip-adapter-plus_sdxl_vit-h.safetensors" }
  },
  "5": {
    "class_type": "LoadImage",
    "inputs": { "image": "{{style_image}}" }
  },
  "6": {
    "class_type": "IPAdapter",
    "inputs": {
      "model": ["1", 0],
      "ipadapter": ["4", 0],
      "image": ["5", 0],
      "weight": "{{ip_weight}}",
      "noise": 0.0,
      "weight_type": "style transfer (medium)",
      "start_at": 0.0,
      "end_at": 1.0,
      "unfold_batch": false,
      "embeds_scaling": "V only"
    }
  },
  "7": {
    "class_type": "ControlNetLoader",
    "inputs": { "ckpt_name": "controlnet-union-sdxl-1.0.safetensors" }
  },
  "8": {
    "class_type": "LoadImage",
    "inputs": { "image": "{{control_image}}" }
  },
  "9": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["2", 0],
      "negative": ["3", 0],
      "control_net": ["7", 0],
      "image": ["8", 0],
      "strength": "{{control_strength}}",
      "start_percent": 0.0,
      "end_percent": 1.0,
      "type": "{{control_type}}"
    }
  },
  "10": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["6", 0],
      "positive": ["9", 0],
      "negative": ["9", 1],
      "latent_image": ["11", 0],
      "seed": "{{seed}}",
      "steps": "{{steps}}",
      "cfg": "{{cfg}}",
      "sampler_name": "{{sampler}}",
      "scheduler": "{{scheduler}}",
      "denoise": 1.0
    }
  },
  "11": {
    "class_type": "EmptyLatentImage",
    "inputs": { "width": "{{width}}", "height": "{{height}}", "batch_size": 1 }
  },
  "12": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["10", 0], "vae": ["1", 0] }
  },
  "13": {
    "class_type": "UpscaleModelLoader",
    "inputs": { "model_name": "{{upscale_model}}" }
  },
  "14": {
    "class_type": "ImageUpscaleWithModel",
    "inputs": { "upscale_model": ["13", 0], "image": ["12", 0] }
  },
  "15": {
    "class_type": "SaveImage",
    "inputs": { "images": ["14", 0] }
  }
}
